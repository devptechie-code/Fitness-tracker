# Copy to .env and fill in. NEVER commit the real .env.
# ⚠️ The old hardcoded Gemini key was exposed in public git history —
#    regenerate it at https://aistudio.google.com/apikey before deploying.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Any long random string; used to sign login tokens.
JWT_SECRET=generate-a-long-random-string

# Make.com (or similar) webhook that fans out emergency alert emails.
ALERT_WEBHOOK_URL=https://hook.eu1.make.com/your-webhook-id

# Optional SMTP for care-circle update emails. Leave blank to log instead of send.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=VitaCircle <no-reply@vitacircle.app>
